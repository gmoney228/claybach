---
import { TRIP } from '../data/trip';

const tz = 'America/Los_Angeles';
const startStr = new Intl.DateTimeFormat('en-US', {
  timeZone: tz,
  weekday: 'short',
  month: 'short',
  day: 'numeric',
  hour: 'numeric',
  hour12: false,
}).format(TRIP.start);
---

<section id="date-section">
  <p class="section-label">07 &mdash; T&ndash;Minus</p>

  <div class="countdown-display">
    <span class="t-label" data-countdown-label>T&ndash;Minus</span>
    <span class="t-value" data-countdown-value>&mdash;</span>
    <span class="t-label t-label-units" data-countdown-units>days</span>
  </div>

  <p class="countdown-target">Boots on the ground &mdash; {startStr} PT</p>

  <div class="decision-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100">
    <div class="progress-label">
      <span>Countdown progress</span>
      <span class="progress-pct" data-progress-pct>00%</span>
    </div>
    <div class="progress-track">
      <div class="progress-fill" data-progress-fill></div>
    </div>
  </div>
</section>

<script>
  import { initCountdown } from '../scripts/countdown';
  initCountdown();
</script>

<style>
  #date-section {
    text-align: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 88px 24px;
    max-width: none;
    margin: 0;
  }

  .countdown-display {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .countdown-display .t-label {
    font-size: 0.4em;
    font-family: 'DM Mono', monospace;
    color: var(--amber);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 8px;
  }

  .countdown-display .t-value {
    color: var(--rust);
    font-variant-numeric: tabular-nums;
  }

  .countdown-display .t-label-units {
    font-size: 0.25em;
    margin-top: 12px;
    letter-spacing: 0.3em;
  }

  .countdown-target {
    margin-top: 28px;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--cream-dim);
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
  }

  .decision-progress {
    margin: 36px auto 0;
    max-width: 440px;
    text-align: left;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 10px;
  }

  .progress-pct {
    color: var(--amber);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.15em;
  }

  .progress-track {
    height: 6px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, var(--rust), var(--amber));
    transition: width 0.6s ease;
  }
</style>
