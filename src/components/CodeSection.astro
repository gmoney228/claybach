---
import { code } from '../data/code';
---

<section id="code-section">
  <p class="section-label">04 &mdash; The code</p>
  <h2 class="section-title code-title">
    Seven articles. <em>No amendments.</em>
  </h2>

  <ol class="code-list">
    {code.map((article) => (
      <li class="code-article">
        <div class="code-numeral-col">
          <span class="code-numeral">{article.numeral}</span>
        </div>
        <div class="code-body-col">
          <h3 class="code-article-title">
            <span class="code-article-label">Article {article.numeral}</span>
            <span class="code-article-headline">{article.title}</span>
          </h3>
          <p class="code-article-body">{article.body}</p>
        </div>
      </li>
    ))}
  </ol>

  <p class="code-sign">&mdash; Ratified by the crew. Binding on all parties present.</p>
</section>

<style>
  #code-section {
    max-width: 820px;
  }

  .code-title {
    text-align: center;
    margin-bottom: 56px;
  }

  .code-title em {
    font-style: italic;
    color: var(--amber);
  }

  /* ── Article list ──────────────────────────────── */
  .code-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .code-article {
    display: grid;
    grid-template-columns: 84px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
    align-items: start;
  }

  .code-article:first-child { padding-top: 0; }
  .code-article:last-child { border-bottom: none; }

  /* Big Roman numeral, Playfair, amber */
  .code-numeral-col {
    text-align: right;
    padding-top: 4px;
  }

  .code-numeral {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    font-weight: 700;
    font-style: italic;
    color: var(--amber);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .code-body-col {
    min-width: 0;
  }

  .code-article-title {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 8px;
  }

  .code-article-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream-dim);
  }

  .code-article-headline {
    font-family: 'Playfair Display', serif;
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--cream);
    letter-spacing: -0.005em;
    line-height: 1.15;
  }

  .code-article-body {
    font-family: 'DM Mono', monospace;
    font-size: 0.82rem;
    line-height: 1.65;
    color: var(--cream-dim);
    max-width: 56ch;
  }

  /* ── Signature ─────────────────────────────────── */
  .code-sign {
    margin-top: 48px;
    text-align: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    color: var(--cream-dim);
    font-style: italic;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  /* The final article (Wedding) earns rust emphasis. */
  .code-article:last-of-type .code-numeral {
    color: var(--rust);
  }

  @media (max-width: 600px) {
    .code-article {
      grid-template-columns: 56px 1fr;
      gap: 18px;
      padding: 22px 0;
    }
    .code-numeral { font-size: 1.8rem; }
    .code-article-headline { font-size: 1.15rem; }
  }
</style>
