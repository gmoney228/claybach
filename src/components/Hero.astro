---
import { TRIP } from '../data/trip';

// Format in Pacific Time so the date stays "July 24" regardless of build host TZ.
const tz = 'America/Los_Angeles';
const partsFor = (d: Date) =>
  Object.fromEntries(
    new Intl.DateTimeFormat('en-US', {
      timeZone: tz,
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
      .formatToParts(d)
      .map((p) => [p.type, p.value])
  );

const startParts = partsFor(TRIP.start);
const endParts = partsFor(TRIP.end);
const eyebrow = `${TRIP.destination} \u00b7 ${startParts.month} ${startParts.day}\u2013${endParts.day}, ${startParts.year}`;
---

<section id="hero">
  <p class="hero-eyebrow">{eyebrow}</p>
  <h1 class="hero-title">
    The <em>Clay Ashworth</em><br />Bachelor Party
  </h1>

  <ul class="hero-stats" aria-label="Trip stats">
    <li class="hero-stat">
      <span class="hero-stat-label">Insertion</span>
      <span class="hero-stat-value">Fri 7.24</span>
    </li>
    <li class="hero-stat">
      <span class="hero-stat-label">Extraction</span>
      <span class="hero-stat-value">Sun 7.26</span>
    </li>
    <li class="hero-stat">
      <span class="hero-stat-label">Theater</span>
      <span class="hero-stat-value">Lake CDA &middot; ID</span>
    </li>
  </ul>

  <a class="hero-cta" href="#itinerary-section">View the itinerary</a>
  <div class="hero-divider"></div>
</section>

<script>
  import { track } from '@vercel/analytics';
  document
    .querySelector('.hero-cta')
    ?.addEventListener('click', () => track('hero_cta_click'));
</script>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 80px 24px 60px;
    position: relative;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, #1c1610 0%, #0e0d0b 70%);
    max-width: none;
    margin: 0;
  }

  #hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 80%, transparent 50%, #0e0d0b 100%);
    pointer-events: none;
  }

  .hero-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 28px;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    color: var(--cream);
    max-width: 820px;
    letter-spacing: -0.01em;
  }

  .hero-title em {
    font-style: italic;
    color: var(--amber);
  }

  /* ── Stat strip ───────────────────────────────── */
  .hero-stats {
    list-style: none;
    margin: 40px 0 0;
    padding: 0;
    display: flex;
    gap: 32px;
    align-items: stretch;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 720px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 0 20px;
    border-right: 1px solid var(--border);
  }

  .hero-stat:last-child { border-right: none; }

  .hero-stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream-dim);
  }

  .hero-stat-value {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--cream);
    letter-spacing: 0.005em;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .hero-cta {
    margin-top: 44px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--amber);
    text-decoration: none;
    border-bottom: 1px solid var(--amber-dim);
    padding-bottom: 6px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-cta:hover {
    color: var(--cream);
    border-color: var(--cream);
  }

  .hero-cta::after {
    content: '\2193';
  }

  .hero-divider {
    margin: 48px auto 0;
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
  }

  @media (max-width: 540px) {
    .hero-stats { gap: 0; flex-wrap: nowrap; }
    .hero-stat { padding: 0 14px; }
    .hero-stat-value { font-size: 0.9rem; }
  }
</style>
