---
import { crew } from '../data/crew';
---

<section id="crew-section">
  <p class="section-label">02.5 &mdash; The crew</p>
  <h2 class="section-title crew-title">
    Six men. <em>One groom.</em>
  </h2>

  <div class="crew-grid">
    {crew.map((m) => (
      <article class="crew-card" data-subject={m.subject ? 'true' : 'false'}>
        <header class="crew-card-header">
          <span class="crew-card-status">{m.status}</span>
        </header>
        <h3 class="crew-card-name">{m.name}</h3>
        <p class="crew-card-role">{m.role}</p>
        <p class="crew-card-intel">{m.intel}</p>
      </article>
    ))}
  </div>
</section>

<style>
  #crew-section {
    max-width: 1080px;
  }

  .crew-title {
    text-align: center;
    margin-bottom: 56px;
  }

  .crew-title em {
    font-style: italic;
    color: var(--amber);
  }

  /* ── 3 × 2 grid; collapses on smaller screens ─── */
  .crew-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 880px) {
    .crew-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 540px) {
    .crew-grid { grid-template-columns: 1fr; }
  }

  /* ── Card ──────────────────────────────────────── */
  .crew-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px 22px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.012);
    position: relative;
  }

  .crew-card-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 6px;
  }

  .crew-card-status {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cream-dim);
    border: 1px solid var(--border);
    padding: 3px 8px;
  }

  .crew-card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .crew-card-role {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--amber);
    text-transform: uppercase;
    line-height: 1.4;
  }

  .crew-card-intel {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--cream-dim);
    line-height: 1.65;
    font-style: italic;
    letter-spacing: 0.015em;
    margin-top: 4px;
  }

  /* ── Subject treatment (Clay only) ─────────────── */
  .crew-card[data-subject='true'] {
    border-color: var(--amber);
    background: rgba(212, 146, 42, 0.05);
  }

  .crew-card[data-subject='true'] .crew-card-status {
    background: var(--amber);
    color: var(--bg);
    border-color: var(--amber);
    font-weight: 500;
  }

  .crew-card[data-subject='true'] .crew-card-name {
    color: var(--cream);
  }

  /* Subtle corner stamp on the subject card. */
  .crew-card[data-subject='true']::before {
    content: '\2716';
    position: absolute;
    top: 12px;
    left: 14px;
    font-size: 0.6rem;
    color: var(--amber);
    opacity: 0.6;
  }
</style>
